{
  "id": "instagram-daily-post-gemini-v1",
  "name": "Instagram Daily Post (Gemini)",
  "description": "Daily: reads first todo row from Google Sheet, generates AI image + caption via Gemini browser automation (free, no API key), posts to Instagram, marks row done.",
  "version": 1,
  "is_active": true,
  "nodes": [
    {
      "id": "gn1",
      "type": "trigger.schedule",
      "name": "Daily 9am",
      "position": { "x": 100, "y": 200 },
      "config": {
        "cron": "0 9 * * *"
      }
    },
    {
      "id": "gn2",
      "type": "service.google_sheets",
      "name": "Read Sheet",
      "position": { "x": 350, "y": 200 },
      "config": {
        "credential_id": "REPLACE_WITH_GOOGLE_CREDENTIAL_ID",
        "spreadsheet_id": "REPLACE_WITH_SPREADSHEET_ID",
        "sheet_name": "Sheet1",
        "operation": "read_rows",
        "range": "A:J",
        "use_header_row": true
      }
    },
    {
      "id": "gn3",
      "type": "core.filter",
      "name": "Filter Todo",
      "position": { "x": 600, "y": 200 },
      "config": {
        "condition": "{{ eq $json.status \"todo\" }}"
      }
    },
    {
      "id": "gn4",
      "type": "core.limit",
      "name": "First Item",
      "position": { "x": 850, "y": 200 },
      "config": {
        "max_items": 1
      }
    },
    {
      "id": "gn5",
      "type": "core.set",
      "name": "Build Prompts",
      "position": { "x": 1100, "y": 200 },
      "config": {
        "assignments": [
          {
            "field": "image_prompt_resolved",
            "value": "{{ if $json.image_prompt }}{{ $json.image_prompt }}{{ else }}Generate a photorealistic, high quality image for an Instagram post about: {{ $json.title }}. {{ $json.description }}. Make it visually stunning and social-media ready. 1024x1024 resolution.{{ end }}",
            "type": "string"
          },
          {
            "field": "caption_prompt_resolved",
            "value": "{{ if $json.caption }}{{ $json.caption }}{{ else }}Write an engaging Instagram caption for a post about: {{ $json.title }}. Context: {{ $json.description }}. Tone: {{ default \"inspirational\" $json.tone }}. Keep it under 150 words. Do not include hashtags. Return only the caption text, nothing else.{{ end }}",
            "type": "string"
          },
          {
            "field": "row_range",
            "value": "Sheet1!H{{ $json._row_index }}:J{{ $json._row_index }}",
            "type": "string"
          }
        ]
      }
    },
    {
      "id": "gn6",
      "type": "gemini.generate_image",
      "name": "Generate Image (Gemini)",
      "position": { "x": 1350, "y": 200 },
      "config": {
        "credential_id": "REPLACE_WITH_GEMINI_SESSION_ID",
        "prompt": "{{ $json.image_prompt_resolved }}",
        "maxWaitSeconds": 120,
        "downloadDir": "~/.monoes/downloads"
      }
    },
    {
      "id": "gn7",
      "type": "gemini.generate_text",
      "name": "Generate Caption (Gemini)",
      "position": { "x": 1600, "y": 200 },
      "config": {
        "credential_id": "REPLACE_WITH_GEMINI_SESSION_ID",
        "prompt": "{{ $json.caption_prompt_resolved }}",
        "maxWaitSeconds": 60
      }
    },
    {
      "id": "gn8",
      "type": "core.set",
      "name": "Build Post Data",
      "position": { "x": 1850, "y": 200 },
      "config": {
        "assignments": [
          {
            "field": "media",
            "value": "[{\"url\": \"{{ (index $json.images 0).path }}\"}]",
            "type": "json"
          },
          {
            "field": "post_text",
            "value": "{{ $json.response_text }}\n\n{{ $json.hashtags }}",
            "type": "string"
          }
        ]
      }
    },
    {
      "id": "gn9",
      "type": "instagram.publish_post",
      "name": "Post to Instagram",
      "position": { "x": 2100, "y": 200 },
      "config": {
        "credential_id": "REPLACE_WITH_INSTAGRAM_CREDENTIAL_ID",
        "media": "{{ $json.media }}",
        "text": "{{ $json.post_text }}"
      }
    },
    {
      "id": "gn10",
      "type": "service.google_sheets",
      "name": "Mark Done",
      "position": { "x": 2350, "y": 200 },
      "config": {
        "credential_id": "REPLACE_WITH_GOOGLE_CREDENTIAL_ID",
        "spreadsheet_id": "REPLACE_WITH_SPREADSHEET_ID",
        "operation": "update_rows",
        "range": "{{ $json.row_range }}",
        "values": [["done", "{{ now }}", ""]]
      }
    }
  ],
  "connections": [
    { "id": "ge1", "source": "gn1", "source_handle": "main", "target": "gn2", "target_handle": "main" },
    { "id": "ge2", "source": "gn2", "source_handle": "main", "target": "gn3", "target_handle": "main" },
    { "id": "ge3", "source": "gn3", "source_handle": "main", "target": "gn4", "target_handle": "main" },
    { "id": "ge4", "source": "gn4", "source_handle": "main", "target": "gn5", "target_handle": "main" },
    { "id": "ge5", "source": "gn5", "source_handle": "main", "target": "gn6", "target_handle": "main" },
    { "id": "ge6", "source": "gn6", "source_handle": "main", "target": "gn7", "target_handle": "main" },
    { "id": "ge7", "source": "gn7", "source_handle": "main", "target": "gn8", "target_handle": "main" },
    { "id": "ge8", "source": "gn8", "source_handle": "main", "target": "gn9", "target_handle": "main" },
    { "id": "ge9", "source": "gn9", "source_handle": "main", "target": "gn10", "target_handle": "main" }
  ]
}
