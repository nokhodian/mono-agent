{
  "actionType": "publish_post",
  "platform": "INSTAGRAM",
  "version": "2.1.0",
  "description": "Publish content (post/story) to Instagram using 3-tier fallback pattern",
  "metadata": {
    "requiresAuth": true,
    "supportsPagination": false,
    "supportsRetry": true
  },
  "inputs": {
    "required": [
      {
        "name": "text",
        "type": "string",
        "description": "Post caption/text"
      },
      {
        "name": "media",
        "type": "string",
        "description": "Media file path or URL"
      }
    ],
    "optional": [
      {
        "name": "locationTag",
        "type": "string",
        "default": "",
        "description": "Location tag for the post"
      },
      {
        "name": "altText",
        "type": "string",
        "default": "",
        "description": "Alt text for accessibility"
      },
      {
        "name": "enableComments",
        "type": "boolean",
        "default": true,
        "description": "Allow comments on post"
      },
      {
        "name": "hideLikeCount",
        "type": "boolean",
        "default": false,
        "description": "Hide like count from viewers"
      },
      {
        "name": "scheduledTime",
        "type": "string",
        "default": "",
        "description": "Schedule publish time (ISO 8601)"
      },
      {
        "name": "tags",
        "type": "string",
        "default": "",
        "description": "Comma-separated hashtags to append"
      },
      {
        "name": "mentionUsers",
        "type": "string",
        "default": "",
        "description": "Comma-separated usernames to mention"
      }
    ]
  },
  "outputs": {
    "success": [],
    "failure": []
  },
  "steps": [
    {
      "id": "tier1_publish",
      "type": "call_bot_method",
      "methodName": "publish_content",
      "args": [
        "{{media[0].url}}",
        "{{text}}",
        "{{locationTag}}"
      ],
      "variable_name": "t1Result",
      "timeout": 120,
      "onError": {
        "action": "skip"
      }
    },
    {
      "id": "check_t1",
      "type": "condition",
      "condition": {
        "variable": "t1Result",
        "operator": "not_exists"
      },
      "then": [
        "navigate_to_create",
        "find_create_button",
        "click_create",
        "wait_for_menu",
        "click_post_option",
        "do_click_post_option",
        "wait_for_dialog",
        "find_file_input",
        "upload_media",
        "wait_for_upload",
        "find_next_button",
        "click_next",
        "wait_for_next2",
        "find_next_button2",
        "click_next2",
        "wait_for_caption_screen",
        "find_caption_input",
        "type_caption",
        "check_has_location",
        "find_share_button",
        "click_share",
        "set_t2_result",
        "check_t2"
      ],
      "else": []
    },
    {
      "id": "navigate_to_create",
      "type": "navigate",
      "url": "https://www.instagram.com/",
      "waitFor": "page_load",
      "timeout": 30
    },
    {
      "id": "find_create_button",
      "type": "find_element",
      "xpath": "//a[contains(@href, '/create')] | //button[contains(@aria-label, 'New post')]",
      "alternatives": [
        "svg[aria-label='New post']",
        "a[href='/create/style/']"
      ],
      "timeout": 10,
      "onError": {
        "action": "skip"
      }
    },
    {
      "id": "click_create",
      "type": "click",
      "elementRef": "find_create_button",
      "onError": {
        "action": "skip"
      }
    },
    {
      "id": "wait_for_menu",
      "type": "wait",
      "duration": 3,
      "waitFor": "time"
    },
    {
      "id": "click_post_option",
      "type": "find_element",
      "xpath": "//span[text()='Post'] | //div[text()='Post'] | //button[contains(.,'Post') and not(contains(.,'Share'))]",
      "timeout": 5,
      "onError": {
        "action": "skip"
      }
    },
    {
      "id": "do_click_post_option",
      "type": "click",
      "elementRef": "click_post_option",
      "onError": {
        "action": "skip"
      }
    },
    {
      "id": "wait_for_dialog",
      "type": "wait",
      "duration": "{{uploadDelay or 5}}",
      "waitFor": "time"
    },
    {
      "id": "find_file_input",
      "type": "find_element",
      "xpath": "//input[@type='file']",
      "timeout": 15,
      "onError": {
        "action": "skip"
      }
    },
    {
      "id": "upload_media",
      "type": "upload",
      "elementRef": "find_file_input",
      "text": "{{media[0].url}}",
      "onError": {
        "action": "skip"
      }
    },
    {
      "id": "wait_for_upload",
      "type": "wait",
      "duration": "{{uploadDelay or 8}}",
      "waitFor": "time"
    },
    {
      "id": "find_next_button",
      "type": "find_element",
      "xpath": "//button[normalize-space(text())='Next'] | //div[@role='button' and normalize-space(text())='Next']",
      "timeout": 15,
      "onError": {
        "action": "skip"
      }
    },
    {
      "id": "click_next",
      "type": "click",
      "elementRef": "find_next_button",
      "onError": {
        "action": "skip"
      }
    },
    {
      "id": "wait_for_next2",
      "type": "wait",
      "duration": 3,
      "waitFor": "time"
    },
    {
      "id": "find_next_button2",
      "type": "find_element",
      "xpath": "//button[normalize-space(text())='Next'] | //div[@role='button' and normalize-space(text())='Next']",
      "timeout": 10,
      "onError": {
        "action": "skip"
      }
    },
    {
      "id": "click_next2",
      "type": "click",
      "elementRef": "find_next_button2",
      "onError": {
        "action": "skip"
      }
    },
    {
      "id": "find_share_button",
      "type": "find_element",
      "xpath": "//button[normalize-space(text())='Share'] | //div[@role='button' and normalize-space(text())='Share']",
      "timeout": 15,
      "onError": {
        "action": "skip"
      }
    },
    {
      "id": "click_share",
      "type": "click",
      "elementRef": "find_share_button",
      "onError": {
        "action": "skip"
      }
    },
    {
      "id": "set_t2_result",
      "type": "set_variable",
      "variable_name": "t2Result",
      "value": true
    },
    {
      "id": "check_t2",
      "type": "condition",
      "condition": {
        "variable": "t2Result",
        "operator": "not_exists"
      },
      "then": [
        "tier3_navigate",
        "tier3_find_create_button",
        "tier3_click_create",
        "tier3_wait_menu",
        "tier3_click_post_option",
        "tier3_do_click_post_option",
        "tier3_wait_for_dialog",
        "find_file_input_t3",
        "upload_media_t3",
        "wait_for_upload_t3",
        "find_next_button_t3",
        "click_next_t3",
        "wait_next2_t3",
        "find_next_button2_t3",
        "click_next2_t3",
        "wait_for_caption_screen_t3",
        "tier3_find_caption_input",
        "type_caption_t3",
        "check_has_location_t3",
        "tier3_find_share_button",
        "click_share_t3"
      ],
      "else": []
    },
    {
      "id": "tier3_navigate",
      "type": "navigate",
      "url": "https://www.instagram.com/",
      "waitFor": "page_load",
      "timeout": 30,
      "onError": {
        "action": "mark_failed"
      }
    },
    {
      "id": "tier3_find_create_button",
      "type": "find_element",
      "xpath": "//a[contains(@href, '/create')] | //button[contains(@aria-label, 'New post')]",
      "alternatives": [
        "svg[aria-label='New post']",
        "a[href='/create/style/']"
      ],
      "timeout": 10,
      "onError": {
        "action": "mark_failed"
      }
    },
    {
      "id": "tier3_click_create",
      "type": "click",
      "elementRef": "tier3_find_create_button",
      "onError": {
        "action": "mark_failed"
      }
    },
    {
      "id": "tier3_wait_menu",
      "type": "wait",
      "duration": 3,
      "waitFor": "time"
    },
    {
      "id": "tier3_click_post_option",
      "type": "find_element",
      "xpath": "//span[text()='Post'] | //div[text()='Post'] | //button[contains(.,'Post') and not(contains(.,'Share'))]",
      "timeout": 5,
      "onError": {
        "action": "skip"
      }
    },
    {
      "id": "tier3_do_click_post_option",
      "type": "click",
      "elementRef": "tier3_click_post_option",
      "onError": {
        "action": "skip"
      }
    },
    {
      "id": "tier3_wait_for_dialog",
      "type": "wait",
      "duration": "{{uploadDelay or 5}}",
      "waitFor": "time"
    },
    {
      "id": "find_file_input_t3",
      "type": "find_element",
      "xpath": "//input[@type='file']",
      "timeout": 15,
      "onError": {
        "action": "mark_failed"
      }
    },
    {
      "id": "upload_media_t3",
      "type": "upload",
      "elementRef": "find_file_input_t3",
      "text": "{{media[0].url}}",
      "onError": {
        "action": "mark_failed"
      }
    },
    {
      "id": "wait_for_upload_t3",
      "type": "wait",
      "duration": "{{uploadDelay or 8}}",
      "waitFor": "time"
    },
    {
      "id": "find_next_button_t3",
      "type": "find_element",
      "xpath": "//button[normalize-space(text())='Next'] | //div[@role='button' and normalize-space(text())='Next']",
      "timeout": 15,
      "onError": {
        "action": "mark_failed"
      }
    },
    {
      "id": "click_next_t3",
      "type": "click",
      "elementRef": "find_next_button_t3",
      "onError": {
        "action": "mark_failed"
      }
    },
    {
      "id": "wait_next2_t3",
      "type": "wait",
      "duration": 3,
      "waitFor": "time"
    },
    {
      "id": "find_next_button2_t3",
      "type": "find_element",
      "xpath": "//button[normalize-space(text())='Next'] | //div[@role='button' and normalize-space(text())='Next']",
      "timeout": 10,
      "onError": {
        "action": "mark_failed"
      }
    },
    {
      "id": "click_next2_t3",
      "type": "click",
      "elementRef": "find_next_button2_t3",
      "onError": {
        "action": "mark_failed"
      }
    },
    {
      "id": "tier3_find_share_button",
      "type": "find_element",
      "xpath": "//button[normalize-space(text())='Share'] | //div[@role='button' and normalize-space(text())='Share']",
      "timeout": 15,
      "onError": {
        "action": "mark_failed"
      }
    },
    {
      "id": "click_share_t3",
      "type": "click",
      "elementRef": "tier3_find_share_button",
      "onError": {
        "action": "mark_failed"
      }
    },
    {
      "id": "wait_for_post_shared",
      "type": "wait",
      "duration": 8,
      "waitFor": "time"
    },
    {
      "id": "navigate_to_profile",
      "type": "navigate",
      "url": "https://www.instagram.com/planet_cute_cats/",
      "timeout": 15
    },
    {
      "id": "wait_profile_load",
      "type": "wait",
      "duration": 8,
      "waitFor": "time"
    },
    {
      "id": "find_first_post",
      "type": "find_element",
      "selector": "a[href*='/p/']",
      "timeout": 20,
      "onError": {
        "action": "skip"
      }
    },
    {
      "id": "click_first_post",
      "type": "click",
      "elementRef": "find_first_post",
      "onError": {
        "action": "skip"
      }
    },
    {
      "id": "wait_post_open",
      "type": "wait",
      "duration": 3,
      "waitFor": "time"
    },
    {
      "id": "post_comment_cdp",
      "type": "call_bot_method",
      "methodName": "post_comment_cdp",
      "args": [
        "{{text}}"
      ],
      "variable_name": "commentResult",
      "timeout": 30,
      "onError": {
        "action": "skip"
      }
    },
    {
      "id": "wait_final",
      "type": "wait",
      "duration": 3,
      "waitFor": "time"
    }
  ],
  "errorHandling": {
    "globalRetries": 3,
    "retryDelay": 2000,
    "onFinalFailure": "log_and_continue"
  }
}