{
  "credential_platform": "linear",
  "fields": [
    { "key": "credential_id", "label": "Linear Connection", "type": "credential_picker", "required": true },
    { "key": "team_id", "label": "Team", "type": "resource_picker", "required": true, "resource": { "type": "teams", "create_label": null } },
    { "key": "operation", "label": "Operation", "type": "select", "required": true, "options": ["list_issues", "create_issue", "update_issue", "list_projects"], "default": "list_issues" },
    { "key": "title", "label": "Issue Title", "type": "text", "required": false, "depends_on": { "key": "operation", "values": ["create_issue"] } },
    { "key": "description", "label": "Description", "type": "textarea", "required": false, "rows": 4, "depends_on": { "key": "operation", "values": ["create_issue"] } },
    { "key": "priority", "label": "Priority", "type": "select", "required": false, "options": ["0", "1", "2", "3", "4"], "default": "0", "depends_on": { "key": "operation", "values": ["create_issue"] } }
  ]
}
