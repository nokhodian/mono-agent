{
  "credential_platform": "github",
  "fields": [
    { "key": "credential_id", "label": "GitHub Account", "type": "credential_picker", "required": true },
    { "key": "repo", "label": "Repository", "type": "resource_picker", "required": true, "resource": { "type": "repos", "create_label": null } },
    { "key": "operation", "label": "Operation", "type": "select", "required": true, "options": ["list_issues", "create_issue", "close_issue", "list_prs", "get_file", "create_file"], "default": "list_issues" },
    { "key": "title", "label": "Issue/PR Title", "type": "text", "required": false, "depends_on": { "key": "operation", "values": ["create_issue"] } },
    { "key": "body", "label": "Body", "type": "textarea", "required": false, "rows": 5, "depends_on": { "key": "operation", "values": ["create_issue"] } }
  ]
}
